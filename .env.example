# Copy this file to .env and fill in your API keys
GROQ_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_AI_STUDIO_KEY=
HUGGINGFACE_TOKEN=
GITHUB_TOKEN=
DB_PATH=securepipe.db
